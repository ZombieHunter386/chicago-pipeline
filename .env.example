# Socrata credentials. Two options (pick one):
# (1) Legacy App Token — set SOCRATA_APP_TOKEN.
# (2) API Key pair — set both SOCRATA_API_KEY_ID and SOCRATA_API_KEY_SECRET.
# Register at https://data.cityofchicago.org/profile/edit/developer_settings
SOCRATA_APP_TOKEN=
SOCRATA_API_KEY_ID=
SOCRATA_API_KEY_SECRET=
# SQLite file path (default: data/pipeline.db)
PIPELINE_DB_PATH=data/pipeline.db
